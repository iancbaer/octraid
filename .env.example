# OctraID Registry Wallet (generated by wallet-gen, stored in WALLET.txt)
REGISTRY_ADDRESS=octAyje5VdK8RJAfsVczbhGdmdyeXMoWciWbsXLCNBbWt1g
REGISTRY_PRIVATE_KEY=

# Octra Network RPC
OCTRA_RPC_URL=https://octra.network

# Circle addresses (populated after running scripts/deploy.ts)
IDENTITY_CIRCLE_ID=
REPUTATION_CIRCLE_ID=
MANDATE_CIRCLE_ID=

# Database (SQLite)
DATABASE_URL=file:./octraid.db

# API
PORT=3000

# JWT signing secret for threshold + mandate attestations
# In production: derive from REGISTRY_PRIVATE_KEY or use a strong random secret
JWT_SECRET=change-me-in-production

# Dashboard API URL (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
