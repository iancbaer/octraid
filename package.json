{
  "name": "octraid",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev --workspace=apps/registry-api",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
